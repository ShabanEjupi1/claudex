# Example environment for the two services. In production these values are
# rendered by Ansible from ansible-vault / HashiCorp Vault into a root-owned,
# 0600 systemd EnvironmentFile. DO NOT put real secrets in this file.

# ---- Ingest API (write-only) ----
INGEST_DB_URL=postgresql://app_ingest@127.0.0.1:5432/audit?sslmode=verify-full
# sha256 hex of the bearer token issued to collectors:
#   printf '%s' "$TOKEN" | sha256sum
INGEST_TOKEN_SHA256=<sha256-hex-of-collector-token>
INGEST_HMAC_KEY=<random-32+-byte-key>
SCHEMA_PATH=schemas/ingest-finding.schema.json

# ---- Dashboard (read) ----
DASHBOARD_DB_URL=postgresql://app_dashboard@127.0.0.1:5432/audit?sslmode=verify-full
SESSION_SECRET=<random-32+-byte-key>
OIDC_ISSUER=https://idp.internal/realms/audit
OIDC_CLIENT_ID=audit-dashboard
OIDC_CLIENT_SECRET=<oidc-client-secret>
OIDC_REDIRECT_URL=https://dashboard.internal/auth/callback
OIDC_ROLE_CLAIM=groups
OIDC_ZONES_CLAIM=zones
