# Keep the build context lean, but DON'T exclude files the images copy
# (app image: app/ + schemas/; scanner image: scripts/discovery/ + deploy/docker/scanner/).
.git
.gitignore
**/.env
**/__pycache__/
**/*.pyc
.venv/
.pytest_cache/
audit-output/
*.nmap
*.gnmap
*.xml
docs/
deploy/ansible/
deploy/*.md
deploy/docker/*.md
schemas/*.md
app/tests/
