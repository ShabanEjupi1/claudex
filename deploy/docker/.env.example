# Copy to .env (git-ignored) and fill in. Generate strong values with:
#   openssl rand -base64 32
# and a token hash with:
#   printf '%s' "$YOUR_COLLECTOR_TOKEN" | sha256sum   # use the hex output

# ---- Postgres ----
POSTGRES_PASSWORD=        # superuser (audit_admin) password
INGEST_DB_PASSWORD=       # password for the write-only app_ingest role
DASHBOARD_DB_PASSWORD=    # password for the read app_dashboard role

# ---- Dashboard ----
SESSION_SECRET=           # >=32 random bytes (signs the session cookie)

# OIDC — REQUIRED for login. The issuer must be reachable BOTH from the
# dashboard container (server-side metadata/token) AND the user's browser
# (the login redirect). An internal-only IdP will not work for public users.
OIDC_ISSUER=https://your-idp.example.com/realms/audit
OIDC_CLIENT_ID=audit-dashboard
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=https://audit.spacecode.tech/auth/callback
OIDC_ROLE_CLAIM=groups
OIDC_ZONES_CLAIM=zones

# ---- Ingest (only needed once you add an mTLS front for collectors) ----
INGEST_TOKEN_SHA256=      # sha256 HEX of the collector bearer token
INGEST_HMAC_KEY=          # >=32 random bytes, shared with collectors
