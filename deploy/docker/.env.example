# Copy to .env (git-ignored) and fill in.
#   DB passwords go inside a URL DSN, so they MUST be URL-safe — generate with
#   hex:    openssl rand -hex 32
#   Other secrets (no URL) can be:   openssl rand -base64 32
#   Token hash:   printf '%s' "$YOUR_TOKEN" | sha256sum   # use the hex output

# ---- Postgres (URL-safe / hex values only — they're embedded in the DSN) ----
POSTGRES_PASSWORD=        # superuser (audit_admin) password
INGEST_DB_PASSWORD=       # password for the write-only app_ingest role
DASHBOARD_DB_PASSWORD=    # password for the read app_dashboard role

# ---- Dashboard ----
SESSION_SECRET=           # >=32 random bytes (signs the session cookie)

# OIDC — REQUIRED for login. Issuer must be reachable from the dashboard
# container AND the user's browser. (Cloudflare Access OIDC works well.)
OIDC_ISSUER=https://your-idp.example.com/realms/audit
OIDC_CLIENT_ID=audit-dashboard
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=https://audit.spacecode.tech/auth/callback
OIDC_ROLE_CLAIM=groups
OIDC_ZONES_CLAIM=zones
# Optional: comma-separated emails always granted ADMIN (break-glass for
# single-owner setups without IdP group provisioning). Match your login email.
ADMIN_EMAILS=

# ---- Ingest ----
# The collector bearer token, in PLAINTEXT. The ingest API hashes it itself and
# the scanner/collectors send it. (Alternatively set INGEST_TOKEN_SHA256 instead.)
INGEST_TOKEN=
INGEST_HMAC_KEY=          # >=32 random bytes, shared with collectors
# No mTLS proxy in the Docker deploy: keep token+HMAC, skip the mTLS header.
# Leave false unless you put an mTLS-terminating nginx in front of ingest.
INGEST_REQUIRE_MTLS=false

# ---- Background scanner (only used with: docker compose --profile scanner up -d) ----
SCAN_TARGETS=                       # space-separated CIDRs, e.g. "10.10.173.0/24 10.10.20.0/24"
NMAP_ARGS=-sS -sV -T4 --top-ports 1000 -Pn   # tune scan speed/coverage
SCAN_INTERVAL_HOURS=6               # rescan cadence
RUN_ON_START=true                   # scan immediately on container start
