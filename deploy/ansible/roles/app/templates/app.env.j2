# Managed by Ansible — rendered from group_vars/vault.yml. Root-owned, 0640.
# Ingest (write-only)
INGEST_DB_URL=postgresql://app_ingest:{{ vault_pg_ingest_password | urlencode }}@127.0.0.1:5432/audit?sslmode=verify-full
INGEST_TOKEN_SHA256={{ vault_ingest_token | hash('sha256') }}
INGEST_HMAC_KEY={{ vault_ingest_hmac_key }}
SCHEMA_PATH=schemas/ingest-finding.schema.json

# Dashboard (read)
DASHBOARD_DB_URL=postgresql://app_dashboard:{{ vault_pg_dashboard_password | urlencode }}@127.0.0.1:5432/audit?sslmode=verify-full
SESSION_SECRET={{ vault_session_secret }}
OIDC_ISSUER={{ oidc_issuer }}
OIDC_CLIENT_ID={{ oidc_client_id }}
OIDC_CLIENT_SECRET={{ vault_oidc_client_secret }}
OIDC_REDIRECT_URL=https://{{ dashboard_server_name }}/auth/callback
OIDC_ROLE_CLAIM={{ oidc_role_claim }}
OIDC_ZONES_CLAIM={{ oidc_zones_claim }}
