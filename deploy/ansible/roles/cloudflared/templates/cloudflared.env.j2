# Managed by Ansible. Connector token for the remotely-managed tunnel.
# Read by systemd (as root) and passed to cloudflared via the environment, so the
# secret never appears in the process arg list. Routing/public hostnames are set
# in the Cloudflare dashboard, not here.
TUNNEL_TOKEN={{ vault_cf_tunnel_token }}
{% if cloudflare_tunnel_protocol != 'auto' %}
TUNNEL_TRANSPORT_PROTOCOL={{ cloudflare_tunnel_protocol }}
{% endif %}
